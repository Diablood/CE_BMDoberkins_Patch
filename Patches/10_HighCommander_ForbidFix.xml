<?xml version="1.0" encoding="utf-8"?>
<Patch>

    <!-- ===================================================== -->
    <!-- FIX: High Commander apparel not forbiddable           -->
    <!-- Cause: missing CompProperties_Forbiddable in parent   -->
    <!-- ===================================================== -->

    <Operation Class="PatchOperationConditional">
        <xpath>/Defs/ThingDef[@Name="DoberCommander_ApparelBase"]/comps/li[@Class="CompProperties_Forbiddable"]</xpath>
        <nomatch Class="PatchOperationAdd">
            <xpath>/Defs/ThingDef[@Name="DoberCommander_ApparelBase"]/comps</xpath>
            <value>
                <li Class="CompProperties_Forbiddable"/>
            </value>
        </nomatch>

    </Operation>

</Patch>